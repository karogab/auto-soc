// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum PostStatus {
  pending
  approved
  rejected
  deleted
}

enum ReactionType {
  like
  dislike
}

enum NotificationType {
  like
  dislike
}

enum ReportReason {
  spam
  offensive
  false_information
  inappropriate
  other
}

enum ReportStatus {
  new
  reviewed
  dismissed
  action_taken
}

enum QuestionStatus {
  new
  read
  answered
}

enum SuggestionStatus {
  new
  reviewed
  planned
  rejected
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  username           String   @unique
  usernameNormalized String   @unique
  firstName          String
  lastName           String
  role               UserRole @default(user)
  isVerified         Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  posts                  Post[]         @relation("AuthoredPosts")
  reactions              Reaction[]
  reports                Report[]       @relation("ReporterReports")
  questions              Question[]
  suggestions            Suggestion[]
  approvedAsAdmin        Post[]         @relation("ApprovedByAdmin")
  rejectedAsAdmin        Post[]         @relation("RejectedByAdmin")
  receivedNotifications  Notification[] @relation("ReceivedNotifications")
  triggeredNotifications Notification[] @relation("TriggeredNotifications")

  @@index([usernameNormalized])
}

model Post {
  id                      String     @id @default(cuid())
  authorId                String
  text                    String
  status                  PostStatus @default(pending)
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  approvedAt              DateTime?
  approvedByAdminId       String?
  rejectedAt              DateTime?
  rejectedByAdminId       String?
  pinnedOnRecommendations Boolean    @default(false)

  author          User           @relation("AuthoredPosts", fields: [authorId], references: [id], onDelete: Cascade)
  approvedByAdmin User?          @relation("ApprovedByAdmin", fields: [approvedByAdminId], references: [id])
  rejectedByAdmin User?          @relation("RejectedByAdmin", fields: [rejectedByAdminId], references: [id])
  reactions       Reaction[]
  reports         Report[]
  notifications   Notification[]

  @@index([status])
  @@index([authorId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  actorId     String
  postId      String
  type        NotificationType
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  recipient User @relation("ReceivedNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User @relation("TriggeredNotifications", fields: [actorId], references: [id], onDelete: Cascade)
  post      Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([recipientId, actorId, postId])
  @@index([recipientId])
  @@index([actorId])
  @@index([postId])
  @@index([isRead])
  @@index([createdAt])
}

model Report {
  id         String       @id @default(cuid())
  postId     String
  reporterId String
  reason     ReportReason
  comment    String?
  status     ReportStatus @default(new)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter User @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
  @@index([status])
}

model Question {
  id        String         @id @default(cuid())
  userId    String
  subject   String?
  message   String
  status    QuestionStatus @default(new)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Suggestion {
  id        String           @id @default(cuid())
  userId    String
  message   String
  status    SuggestionStatus @default(new)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

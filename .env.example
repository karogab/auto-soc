# Neon PostgreSQL (sslmode=require recommended)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/dbname?sslmode=require"

# Auth.js / NextAuth — use a long random value in production
AUTH_SECRET="replace-with-openssl-rand-base64-32-or-similar"
AUTH_URL="http://localhost:3000"

# Legacy aliases (optional)
NEXTAUTH_SECRET=""
NEXTAUTH_URL=""

# Google Form opened from "Request verification" on /account
NEXT_PUBLIC_VERIFICATION_FORM_URL="https://forms.google.com/..."

# Optional: create/update a dev admin on `pnpm db:seed` (skipped in production)
# ADMIN_SEED_EMAIL="admin@example.com"
# ADMIN_SEED_PASSWORD="change-me"
# ADMIN_SEED_USERNAME="admin"
# ADMIN_SEED_FIRST_NAME="Admin"
# ADMIN_SEED_LAST_NAME="User"
